include "./code/lang/String.code"

define main = func () -> Nothing {
    let map_item = new Map_Item[String, Array[i32]]
    let array = new Array[i32]
    array.array[0] = 42
}

define Array = struct [T] {
    array: [T; ?]
    length: usize
}

\ TODO: report duplicate struct type
define Array = struct {
    array: [i32; ?]
    length: usize
}

define Map_Item = struct [K, V] {
    key: K
    value: V
}
